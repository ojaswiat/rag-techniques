flowchart TD
  RAW["fa:fa-file-code Raw 10-K Filings"] --> PARSE["fa:fa-cogs Parse + Chunk<br/>metadata + node_id"]
  PARSE --> NODES["fa:fa-database Node Store"]
  NODES --> SUM["fa:fa-stream P3 Summary Index Build<br/>llama-3.1-8b-instant · one-time"]
  NODES --> GEN["fa:fa-robot Generate 140 Queries<br/>Generator: gpt-oss-120b"]
  GEN --> CRIT["fa:fa-search Critic Verifies<br/>Qwen3-32b + search tool"]
  CRIT --> POOL["fa:fa-check-double Verified Pool"]
  POOL --> PQ["PQ · 100<br/>test set"]
  POOL --> GQ["GQ · 20<br/>teaching set + HUMAN"]
  POOL --> JEQ["JEQ · 20<br/>eval set"]
  JEQ --> GATE{"fa:fa-balance-scale Judge Validation<br/>Agreement &gt; 80% ?"}
  GQ -.->|few-shot| GATE
  GATE -->|No| FIXJ["fa:fa-wrench Fix Judge<br/>rubric / model"]
  FIXJ -.-> GATE
  GATE -->|Yes| BENCH["fa:fa-flask Full Benchmark<br/>PQ × P1,P2,P3 × K = 3,5,10<br/>= 900 runs"]
  PQ --> BENCH
  SUM -.-> BENCH
  BENCH --> RESULTS["fa:fa-chart-bar Results Store<br/>Analysis and Comparison"]
