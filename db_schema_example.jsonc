// SQLite schema — example rows (JSONC: // comments are not valid in strict JSON)
// 5 tables: nodes, queries, golden_queries, judge_validation, results

{
  // ── 1. nodes ── parsed chunks from LlamaParse. node_id is the CANONICAL evidence anchor (not page numbers).
  "nodes": {
    "node_id": "AAPL_2025_n0421",        // PK. canonical evidence unit used by all retrieval metrics
    "document_id": "SEC_10K_AAPL_2025",  // which filing this chunk belongs to
    "parent_item_header": "Item 8",      // structural section (Item 1A, Item 7, Item 8...)
    "node_type": "table",                // "text" | "table"
    "source_page_num": 62,               // DERIVED, display-only. never used as the match key
    "content": "| Year | Revenue |\n|---|---|\n| 2025 | 394,328 |",  // markdown text or atomic table
    "token_count": 180                   // for context-budget checks during generation
  },

  // ── 2. queries ── the 100 TEST questions. Written by gpt-oss, verified by Qwen critic.
  "queries": {
    "query_id": "Q3_017",                // PK
    "quadrant": "Q3_Direct_Table",       // Q1_Direct_Text | Q2_Implicit_Text | Q3_Direct_Table | Q4_Implicit_Table
    "query_text": "What was total net sales for FY2025?",
    "ground_truth_answer": "$394.3B",    // Answer A (gpt-oss generated)
    "gt_citations": ["AAPL_2025_n0421"], // list of node_ids that prove the answer
    "document_id": "SEC_10K_AAPL_2025",
    "verified": true                     // passed the Qwen critic cross-check
  },

  // ── 3. golden_queries ── the 20 TEACHING examples (few-shot). Question by gpt-oss; SCORE + REASONING by you.
  "golden_queries": {
    "query_id": "G_Q4_03",               // PK. disjoint from `queries`
    "quadrant": "Q4_Implicit_Table",
    "query_text": "Calculate YoY change in total operating expenses for FY2025.",
    "ground_truth_answer": "Decreased 4.2% YoY.",
    "gt_citations": ["AAPL_2025_n0588", "AAPL_2025_n0742"],
    "example_output": "Operating expenses fell about 4% year over year.",  // a sample answer to grade
    "human_score": 8,                    // YOUR 1-10 score for example_output
    "human_reasoning": "Correct direction and magnitude, but vague on the exact figure.",  // why it earned that score — this is the human anchor
    "document_id": "SEC_10K_AAPL_2025"
  },

  // ── 4. judge_validation ── the 12 EXAM items. Questions at generation; output + scores filled AFTER runs.
  "judge_validation": {
    "query_id": "V_Q1_02",               // PK. disjoint from the other two sets
    "quadrant": "Q1_Direct_Text",
    "query_text": "Name the primary risk factor cited for supply chain.",
    "ground_truth_answer": "Single-source component suppliers.",
    "gt_citations": ["AAPL_2025_n0099"],
    "pipeline_output": null,             // Llama's Answer B — written AFTER pipeline run
    "human_score": null,                 // YOUR hand score — written AFTER, by you
    "judge_score": null,                 // Qwen judge's score — written AFTER judge run
    "document_id": "SEC_10K_AAPL_2025"   // agreement rate = compare human_score vs judge_score across the 12
  },

  // ── 5. results ── the 600 benchmark runs (2 pipelines x 3 K-values x 100 queries). Commit one row per run.
  "results": {
    "result_id": "R_000457",             // PK
    "query_id": "Q3_017",                // FK -> queries.query_id
    "pipeline": "P3_vector",             // "P3_vector" | "P4_bm25"
    "k_value": 5,                        // 3 | 5 | 10
    "retrieved_node_ids": ["AAPL_2025_n0421", "AAPL_2025_n0420"],  // what retrieval returned (top-K)
    "pipeline_output": "$394.3B",        // Answer B from Llama 3.3 70B
    "cited_node_ids": ["AAPL_2025_n0421"],  // nodes the answer cited
    "precision_at_k": 0.20,              // relevant retrieved / K
    "recall_at_k": 1.0,                  // distinct GT nodes found / total GT nodes (capped at 1)
    "evidence_hit": true,                // was the key GT node anywhere in top-K
    "citation_match": true,              // code check: cited_node_ids ⊆ gt_citations
    "token_f1": 0.95,                    // lexical overlap vs ground_truth_answer
    "exact_match": true,                 // Q1/Q3 only (number-normalized); null for Q2/Q4
    "judge_score": 9,                    // Qwen judge 1-10 (primary quality metric)
    "latency_sec": 1.84,                 // efficiency pillar
    "input_tokens": 2100,                // efficiency pillar
    "output_tokens": 40                  // efficiency pillar
  }
}
